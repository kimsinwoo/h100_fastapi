# App
APP_NAME=Z-Image AI Service
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=7000
# 7000 사용 중이면 PORT=7001 등으로 변경
# GPU 메모리 부족/다른 프로세스가 GPU 사용 중이면 기동 시 preload 생략 (첫 요청 시 로드)
# SKIP_PIPELINE_PRELOAD=true
# 리버스 프록시 하위 경로일 때 (프론트 baseURL과 일치). 예: 95ce287337c3ad9f
# BASE_PATH=95ce287337c3ad9f

# Paths (relative to backend dir)
STATIC_DIR=static
GENERATED_DIR_NAME=generated
UPLOAD_MAX_SIZE_MB=20

# 이미지 생성: OmniGen(Omni) 사용 시 H100 등에서 Omni 모델 로드 (기본값 true)
USE_OMNIGEN=true
OMNIGEN_MODEL_ID=Shitao/OmniGen-v1-diffusers
# USE_OMNIGEN=false 로 두면 Z-Image-Turbo 사용

# Z-Image model (USE_OMNIGEN=false 일 때만 사용)
MODEL_ID=Tongyi-MAI/Z-Image-Turbo
DEVICE_PREFERENCE=auto
DEFAULT_STRENGTH=0.6
DEFAULT_STEPS=9
DEFAULT_SIZE=1024
USE_AUTOCAST=true

# H100 속도 최적화
# Flash Attention 2: torch 설치된 venv에서만 가능. 반드시 --no-build-isolation 사용.
#   pip install flash-attn --no-build-isolation
#   (빌드 시 torch 필요. 일반 pip install flash-attn 은 ModuleNotFoundError: No module named 'torch' 발생)
# ENABLE_FLASH_ATTENTION_2=true
# Transformer compile: 첫 요청 warmup 후 추가 ~20% 감소. torch.compile 사용 시 TORCH_COMPILE_DISABLE=0 필요할 수 있음
# ENABLE_TORCH_COMPILE=true
# ENABLE_ATTENTION_SLICING=false
# ENABLE_VAE_SLICING=false
# OMNIGEN_MAX_INPUT_SIZE=1024
# 768 이면 더 빠르지만 해상도 낮음

# CORS (comma-separated origins; * for all)
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Rate limiting (동시 100명 사용 시 100~200 권장)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# LLM — 로컬(transformers) 또는 vLLM API
LLM_ENABLED=true
# 로컬: 동시 1건만. 100명 쓰려면 vLLM 사용 (아래 LLM_USE_LOCAL=false)
LLM_USE_LOCAL=true
LLM_LOCAL_MODEL_ID=openai/gpt-oss-20b
# LLM_HF_TOKEN=  ← Hugging Face 게이트일 때만
LLM_TIMEOUT_SECONDS=120
LLM_MAX_CONCURRENT=1
# ---- 100명 동시 사용: vLLM 서버(7001) 사용 시 ----
# LLM_USE_LOCAL=false
# LLM_API_BASE=http://127.0.0.1:7001/v1
# LLM_MAX_CONCURRENT=100

# ComfyUI — LTX i2v / 댄스 pose_sdxl 공통 (상세: docs/COMFYUI_FULL_SETUP.md)
# talktailForPet 레포에서 상위에 ComfyUI/ 가 있으면 경로 자동 출력: bash scripts/print_comfyui_local_env.sh
# 상위 레포 가이드: ../../../COMFYUI.md
# COMFYUI_ENABLED=true
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# LTX 를 diffusers 대신 ComfyUI 로 돌릴 때
# LTX2_USE_COMFYUI=true
# 워크플로 파일명(확장자 없음, backend/pipelines/<이름>.json)
# COMFYUI_LTX23_WORKFLOW=ltx23_i2v
# Wan VACE v2v (이미지+레퍼런스 영상→영상). pipelines/video_wan_vace_14B_v2v.json 필요, ComfyUI에 WanVideoWrapper 등
# WAN_VACE_V2V_ENABLED=false
# COMFYUI_WAN_VACE_V2V_WORKFLOW=video_wan_vace_14B_v2v
# ComfyUI (LTX-2.3 비디오 등). 5분 넘게 걸리면 타임아웃 시 여기서 증가
# COMFYUI_TIMEOUT_SECONDS=900
# 10~20분 걸리는 워크플로는 예: COMFYUI_TIMEOUT_SECONDS=1800
# 영상 전용 타임아웃(미설정 시 위 값 사용). 20분 이상 걸리면 COMFYUI_VIDEO_TIMEOUT_SECONDS=1200 권장
# COMFYUI_VIDEO_TIMEOUT_SECONDS=1200
# 커스텀 댄스 시 레퍼런스 영상을 ComfyUI가 읽을 디렉터리(절대경로). ComfyUI 의 input 과 같게 두면 복사 최소화
# 예(레포 루트 ComfyUI): COMFYUI_REFERENCE_VIDEO_DIR=/.../talktailForPet/ComfyUI/input
# COMFYUI_REFERENCE_VIDEO_DIR=/root/project/h100_fastapi/backend/motions
# (선택) ComfyUI output 과 공유 — 미설정 시 ComfyUI /view 로 가져옴
# COMFYUI_OUTPUT_DIR=/.../talktailForPet/ComfyUI/output

# 댄스 영상 사전 등록 폴더 (비우면 motions 사용). GET /api/dance/list, POST /api/dance/refresh
# DANCE_VIDEOS_DIR_NAME=dance_videos
# 포즈 추출(Tasks API): PoseLandmarker .task 모델 경로. 비우면 data/pose_cache/pose_landmarker.task 자동 다운로드
# POSE_LANDMARKER_MODEL_PATH=/path/to/pose_landmarker.task
